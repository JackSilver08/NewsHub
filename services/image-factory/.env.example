HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=http://localhost:4321,http://127.0.0.1:4321,https://newshub-jack.netlify.app

# ComfyUI and its models remain outside Git. Start it separately on this URL.
COMFYUI_ENABLED=true
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_WORKFLOW=z_image_turbo_api.json
COMFYUI_TIMEOUT_SECONDS=600

WORKER_ID=thumbnail-worker
GPU_ID=0
LOCK_TIMEOUT_SECONDS=900
MAX_RETRIES=1
MAX_PENDING_JOBS_PER_USER=2
MAX_IMAGES_PER_REQUEST=1
MAX_RESOLUTION=1024
ALLOWED_RESOLUTIONS=512,576,768,1024

DEFAULT_MODEL=z-image-turbo
DEFAULT_STEPS=6
DEFAULT_CFG=1.0
DEFAULT_SAMPLER=euler
DEFAULT_SCHEDULER=normal
DEFAULT_WIDTH=768
DEFAULT_HEIGHT=432
