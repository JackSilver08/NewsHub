{
  "1": {
    "class_type": "UNETLoader",
    "_meta": {"title": "Load Z-Image model"},
    "inputs": {"unet_name": "z_image_turbo_int8_convrot.safetensors", "weight_dtype": "default"}
  },
  "2": {
    "class_type": "CLIPLoader",
    "_meta": {"title": "Load text encoder"},
    "inputs": {"clip_name": "qwen_3_4b_fp4_mixed.safetensors", "type": "lumina2", "device": "default"}
  },
  "3": {
    "class_type": "VAELoader",
    "_meta": {"title": "Load VAE"},
    "inputs": {"vae_name": "ae.safetensors"}
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Positive"},
    "inputs": {"text": "a realistic editorial photograph", "clip": ["2", 0]}
  },
  "5": {
    "class_type": "ConditioningZeroOut",
    "_meta": {"title": "Negative conditioning"},
    "inputs": {"conditioning": ["4", 0]}
  },
  "6": {
    "class_type": "EmptySD3LatentImage",
    "_meta": {"title": "Image size"},
    "inputs": {"width": 1024, "height": 576, "batch_size": 1}
  },
  "7": {
    "class_type": "ModelSamplingAuraFlow",
    "_meta": {"title": "Z-Image sampling"},
    "inputs": {"model": ["1", 0], "shift": 3.0}
  },
  "8": {
    "class_type": "KSampler",
    "_meta": {"title": "KSampler"},
    "inputs": {
      "seed": 0,
      "steps": 8,
      "cfg": 1.0,
      "sampler_name": "res_multistep",
      "scheduler": "simple",
      "denoise": 1.0,
      "model": ["7", 0],
      "positive": ["4", 0],
      "negative": ["5", 0],
      "latent_image": ["6", 0]
    }
  },
  "9": {
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode"},
    "inputs": {"samples": ["8", 0], "vae": ["3", 0]}
  },
  "10": {
    "class_type": "SaveImage",
    "_meta": {"title": "Save Image"},
    "inputs": {"filename_prefix": "AIF_ZImage", "images": ["9", 0]}
  }
}
