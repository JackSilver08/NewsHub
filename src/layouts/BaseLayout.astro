---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  /** Extra JSON-LD object to embed (e.g. NewsArticle). */
  jsonLd?: Record<string, unknown>;
  /** Set false to remove the site name suffix from <title>. */
  appendSiteName?: boolean;
}

const {
  title,
  description = 'NewsHub cập nhật tin tức công nghệ, AI, startup, thiết bị và an ninh mạng mới nhất trong ngày.',
  image = '/assets/post-hero.png',
  type = 'website',
  jsonLd,
  appendSiteName = true,
} = Astro.props;

const siteName = 'NewsHub';
const fullTitle = appendSiteName ? `${title} · ${siteName}` : title;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0B1020" />
    <script is:inline>
      // Bật scroll-reveal sớm để tránh nháy nội dung; tắt nếu người dùng
      // yêu cầu giảm chuyển động.
      try {
        if (!window.matchMedia || !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          document.documentElement.classList.add('js-reveal');
        }
      } catch (e) {}
    </script>
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="NewsHub RSS" href="/rss.xml" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="vi_VN" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;600;700;800&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body>
    <a href="#main" class="visually-hidden">Bỏ qua tới nội dung</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Scroll reveal: gắn .in-view khi phần tử lọt vào khung nhìn.
      (function () {
        const html = document.documentElement;
        if (!html.classList.contains('js-reveal')) return;
        const selector = [
          '.hero',
          '.ticker-wrap',
          '.cat-row',
          '.section-head',
          '.card',
          '.brief',
          '.brief-card',
          '.popular',
          '.popular-item',
          '.hero-side-item',
          '[data-reveal]',
        ].join(', ');
        const els = Array.prototype.slice.call(document.querySelectorAll(selector));
        const revealAll = () => els.forEach((el) => el.classList.add('in-view'));
        try {
          if (!('IntersectionObserver' in window)) {
            revealAll();
            return;
          }
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('in-view');
                  io.unobserve(entry.target);
                }
              });
            },
            { rootMargin: '0px 0px -8% 0px', threshold: 0.06 },
          );
          els.forEach((el) => io.observe(el));
        } catch (e) {
          revealAll();
        }
      })();
    </script>
  </body>
</html>
