---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Đăng ký"
  description="Chuyển tới form đăng ký Công Nghệ Thường Nhật."
>
  <section class="redirect-page">
    <p>Đang mở form đăng ký...</p>
    <a href="/login?mode=signup">Mở form đăng ký</a>
  </section>
</BaseLayout>

<style>
  .redirect-page {
    min-height: 50vh;
    display: grid;
    place-items: center;
    align-content: center;
    gap: 12px;
    padding: 48px 20px;
  }
  .redirect-page p {
    margin: 0;
    color: var(--text-muted);
  }
  .redirect-page a {
    color: var(--nh-purple);
    font-weight: 800;
  }
</style>

<script>
  window.location.replace('/login?mode=signup');
</script>
