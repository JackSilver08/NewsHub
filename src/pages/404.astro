---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedPosts, postSlug } from '../lib/posts';

const latest = (await getPublishedPosts()).slice(0, 4);
---

<BaseLayout title="Không tìm thấy trang" description="Trang bạn tìm không tồn tại.">
  <div class="container notfound">
    <p class="nf-code">404</p>
    <h1>Không tìm thấy bài viết</h1>
    <p class="nf-desc">
      Đường dẫn có thể đã thay đổi hoặc bài viết không tồn tại. Bạn có thể quay về
      trang chủ hoặc đọc một trong những tin mới nhất bên dưới.
    </p>
    <a href="/" class="btn btn-primary">Về trang chủ</a>

    <ul class="nf-list">
      {latest.map((p) => (
        <li><a href={`/article/${postSlug(p)}`}>{p.data.title}</a></li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .notfound {
    padding: 60px 20px 80px;
    text-align: center;
    max-width: 640px;
  }
  .nf-code {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: clamp(4rem, 14vw, 7rem);
    line-height: 1;
    margin: 0;
    background: var(--nh-grad);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .notfound h1 {
    font-size: 1.8rem;
    margin: 8px 0 12px;
  }
  .nf-desc {
    color: var(--text-soft);
    margin-bottom: 22px;
  }
  .nf-list {
    list-style: none;
    padding: 0;
    margin: 40px auto 0;
    display: grid;
    gap: 10px;
    text-align: left;
    max-width: 460px;
  }
  .nf-list a {
    display: block;
    padding: 12px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.94rem;
  }
  .nf-list a:hover {
    border-color: var(--nh-purple);
    color: var(--nh-purple);
  }
</style>
