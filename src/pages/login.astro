---
import BaseLayout from '../layouts/BaseLayout.astro';

const next = Astro.url.searchParams.get('next') || '/admin/index.html';
---

<BaseLayout
  title="Đăng nhập"
  description="Đăng nhập vào khu vực quản trị NewsHub."
>
  <section class="auth-page" data-next={next}>
    <div class="auth-shell">
      <div class="auth-visual" aria-hidden="true"></div>

      <form class="auth-card" id="loginForm" novalidate>
        <div class="form-head">
          <span>NewsHub Admin</span>
          <h2>Chào mừng trở lại</h2>
        </div>

        <label>
          Email
          <input
            type="email"
            name="email"
            autocomplete="email"
            placeholder="Nhập email"
            required
          />
        </label>

        <label>
          Mật khẩu
          <input
            type="password"
            name="password"
            autocomplete="current-password"
            placeholder="Nhập mật khẩu"
            required
          />
        </label>

        <p class="form-error" id="loginError" hidden>Email hoặc mật khẩu chưa đúng.</p>

        <button type="submit">Đăng nhập</button>
        <p class="form-note">Chưa có tài khoản? <a href="/signup">Đăng ký</a></p>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .auth-page {
    position: relative;
    overflow: hidden;
    min-height: calc(100vh - 64px);
    display: grid;
    place-items: center;
    padding: 48px 20px;
    background: url('/assets/login-tech-news-hero.png') center / cover no-repeat;
  }
  .auth-shell {
    position: relative;
    z-index: 1;
    width: min(100%, 980px);
    display: grid;
    grid-template-columns: minmax(0, 1fr) 420px;
    gap: 28px;
    align-items: center;
  }
  .auth-visual {
    min-height: 620px;
  }
  .auth-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 8px;
    box-shadow: 0 24px 70px rgba(15, 23, 42, 0.16);
    padding: 28px;
    display: grid;
    gap: 18px;
  }
  .form-head span {
    display: inline-flex;
    color: var(--nh-purple);
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 8px;
  }
  .form-head h2 {
    margin: 0;
    font-size: 1.55rem;
  }
  label {
    display: grid;
    gap: 8px;
    color: var(--text-soft);
    font-weight: 700;
    font-size: 0.9rem;
  }
  input {
    width: 100%;
    border: 1px solid var(--border-strong);
    border-radius: 8px;
    padding: 13px 14px;
    font: inherit;
    color: var(--text);
    background: var(--surface);
  }
  input:focus {
    outline: 2px solid var(--ring);
    border-color: var(--nh-purple);
  }
  button {
    min-height: 46px;
    border: 0;
    border-radius: 8px;
    background: var(--nh-grad);
    color: #fff;
    font-family: var(--font-head);
    font-size: 0.95rem;
    font-weight: 800;
    cursor: pointer;
  }
  .form-error {
    margin: 0;
    color: #b91c1c;
    background: #fee2e2;
    border-radius: 8px;
    padding: 10px 12px;
    font-size: 0.9rem;
  }
  .form-note {
    margin: 0;
    color: var(--text-muted);
    text-align: center;
    font-size: 0.92rem;
  }
  .form-note a {
    color: var(--nh-purple);
    font-weight: 800;
  }

  @media (max-width: 820px) {
    .auth-page {
      align-items: start;
      background-position: 37% center;
    }
    .auth-shell {
      grid-template-columns: 1fr;
    }
    .auth-visual {
      display: none;
    }
  }
</style>

<script>
  const ADMIN_EMAIL = 'admin@newshub.com';
  const ADMIN_PASSWORD = 'admin@1234';
  const page = document.querySelector<HTMLElement>('.auth-page');
  const form = document.querySelector<HTMLFormElement>('#loginForm');
  const error = document.querySelector<HTMLElement>('#loginError');
  const nextUrl = page?.dataset.next || '/admin/index.html';

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    const formData = new FormData(form);
    const email = String(formData.get('email') || '').trim().toLowerCase();
    const password = String(formData.get('password') || '');

    if (email === ADMIN_EMAIL && password === ADMIN_PASSWORD) {
      localStorage.setItem(
        'newshubAuth',
        JSON.stringify({
          email,
          name: 'NewsHub Admin',
          role: 'admin',
          signedInAt: new Date().toISOString(),
        }),
      );
      window.location.href = nextUrl;
      return;
    }

    if (error) error.hidden = false;
  });
</script>
