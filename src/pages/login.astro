---
import BaseLayout from '../layouts/BaseLayout.astro';

const next = Astro.url.searchParams.get('next') || '/admin/index.html';
---

<BaseLayout
  title="Đăng nhập"
  description="Đăng nhập vào khu vực quản trị Công Nghệ Thường Nhật."
>
  <section class="auth-page" data-next={next}>
    <div class="auth-shell">
      <div class="auth-visual" aria-hidden="true"></div>

      <form class="auth-card" id="loginForm" data-auth-panel="login" novalidate>
        <div class="form-head">
          <span>Thường Nhật Admin</span>
          <h2>Chào mừng trở lại</h2>
        </div>

        <label>
          Email
          <input
            type="email"
            name="email"
            autocomplete="email"
            placeholder="Nhập email"
            required
          />
        </label>

        <label>
          Mật khẩu
          <input
            type="password"
            name="password"
            autocomplete="current-password"
            placeholder="Nhập mật khẩu"
            required
          />
        </label>

        <p class="form-error" id="loginError" hidden>Email hoặc mật khẩu chưa đúng.</p>

        <button type="submit">Đăng nhập</button>
        <p class="form-note">Chưa có tài khoản ? <a href="?mode=signup" data-show-signup>Đăng kí</a></p>
      </form>

      <form class="auth-card" id="signupForm" data-auth-panel="signup" hidden novalidate>
        <div class="form-head">
          <span>Tài khoản mới</span>
          <h2>Đăng kí</h2>
        </div>

        <label>
          Họ tên
          <input
            type="text"
            name="name"
            autocomplete="name"
            placeholder="Nhập họ tên"
            required
          />
        </label>

        <label>
          Email
          <input
            type="email"
            name="email"
            autocomplete="email"
            placeholder="Nhập email"
            required
          />
        </label>

        <label>
          Mật khẩu
          <input
            type="password"
            name="password"
            autocomplete="new-password"
            placeholder="Tối thiểu 6 ký tự"
            minlength="6"
            required
          />
        </label>

        <p class="form-message" id="signupMessage" hidden></p>

        <button type="submit">Tạo tài khoản</button>
        <p class="form-note">Đã có tài khoản ? <a href="?mode=login" data-show-login>Đăng nhập</a></p>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .auth-page {
    position: relative;
    overflow: hidden;
    min-height: calc(100vh - 64px);
    display: grid;
    place-items: center;
    padding: 48px 20px;
    background: url('/assets/login-tech-news-hero.png') center / cover no-repeat;
  }
  .auth-shell {
    position: relative;
    z-index: 1;
    width: min(100%, 980px);
    display: grid;
    grid-template-columns: minmax(0, 1fr) 420px;
    gap: 28px;
    align-items: center;
  }
  .auth-visual {
    min-height: 620px;
  }
  .auth-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 8px;
    box-shadow: 0 24px 70px rgba(15, 23, 42, 0.16);
    padding: 28px;
    display: grid;
    gap: 18px;
  }
  .auth-card[hidden] {
    display: none;
  }
  .form-head span {
    display: inline-flex;
    color: var(--nh-purple);
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 8px;
  }
  .form-head h2 {
    margin: 0;
    font-size: 1.55rem;
  }
  label {
    display: grid;
    gap: 8px;
    color: var(--text-soft);
    font-weight: 700;
    font-size: 0.9rem;
  }
  input {
    width: 100%;
    border: 1px solid var(--border-strong);
    border-radius: 8px;
    padding: 13px 14px;
    font: inherit;
    color: var(--text);
    background: var(--surface);
  }
  input:focus {
    outline: 2px solid var(--ring);
    border-color: var(--nh-purple);
  }
  button {
    min-height: 46px;
    border: 0;
    border-radius: 8px;
    background: var(--nh-grad);
    color: #fff;
    font-family: var(--font-head);
    font-size: 0.95rem;
    font-weight: 800;
    cursor: pointer;
  }
  .form-error {
    margin: 0;
    color: #b91c1c;
    background: #fee2e2;
    border-radius: 8px;
    padding: 10px 12px;
    font-size: 0.9rem;
  }
  .form-message {
    margin: 0;
    border-radius: 8px;
    padding: 10px 12px;
    font-size: 0.9rem;
  }
  .form-message.success {
    color: #166534;
    background: #dcfce7;
  }
  .form-message.error {
    color: #b91c1c;
    background: #fee2e2;
  }
  .form-note {
    margin: 0;
    color: var(--text-muted);
    text-align: center;
    font-size: 0.92rem;
  }
  .form-note a {
    color: #2563eb;
    font-weight: 800;
  }
  .form-note a:hover {
    color: #1d4ed8;
  }

  @media (max-width: 820px) {
    .auth-page {
      align-items: start;
      background-position: 37% center;
    }
    .auth-shell {
      grid-template-columns: 1fr;
    }
    .auth-visual {
      display: none;
    }
  }
</style>

<script>
  import { supabaseBrowser, getCurrentUser } from '../lib/supabaseBrowser';

  const page = document.querySelector<HTMLElement>('.auth-page');
  const loginForm = document.querySelector<HTMLFormElement>('#loginForm');
  const signupForm = document.querySelector<HTMLFormElement>('#signupForm');
  const loginPanel = document.querySelector<HTMLElement>('[data-auth-panel="login"]');
  const signupPanel = document.querySelector<HTMLElement>('[data-auth-panel="signup"]');
  const error = document.querySelector<HTMLElement>('#loginError');
  const signupMessage = document.querySelector<HTMLElement>('#signupMessage');
  const showSignup = document.querySelector<HTMLAnchorElement>('[data-show-signup]');
  const showLogin = document.querySelector<HTMLAnchorElement>('[data-show-login]');
  const nextUrl = page?.dataset.next || '/admin/index.html';

  /** Điều hướng sau khi đăng nhập theo role. */
  function redirectAfterAuth(role: string) {
    const isStaff = role === 'admin' || role === 'moderator';
    if (nextUrl.startsWith('/admin') && !isStaff) {
      window.location.href = '/account';
    } else {
      window.location.href = nextUrl;
    }
  }

  function setMode(mode: 'login' | 'signup', pushState = true) {
    if (loginPanel && signupPanel) {
      loginPanel.hidden = mode !== 'login';
      signupPanel.hidden = mode !== 'signup';
    }

    if (pushState) {
      const url = new URL(window.location.href);
      if (mode === 'signup') {
        url.searchParams.set('mode', 'signup');
      } else {
        url.searchParams.delete('mode');
      }
      window.history.pushState({ mode }, '', url);
    }
  }

  function showLoginError(text?: string) {
    if (!error) return;
    if (text) error.textContent = text;
    error.hidden = false;
  }

  function showSignupMessage(text: string, type: 'success' | 'error') {
    if (!signupMessage) return;
    signupMessage.textContent = text;
    signupMessage.className = `form-message ${type}`;
    signupMessage.hidden = false;
  }

  function setBusy(form: HTMLFormElement, busy: boolean) {
    const button = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (button) button.disabled = busy;
  }

  showSignup?.addEventListener('click', (event) => {
    event.preventDefault();
    setMode('signup');
  });

  showLogin?.addEventListener('click', (event) => {
    event.preventDefault();
    setMode('login');
  });

  window.addEventListener('popstate', () => {
    const mode = new URLSearchParams(window.location.search).get('mode');
    setMode(mode === 'signup' ? 'signup' : 'login', false);
  });

  const initialMode = new URLSearchParams(window.location.search).get('mode');
  setMode(initialMode === 'signup' ? 'signup' : 'login', false);

  // Đã đăng nhập sẵn thì chuyển thẳng.
  getCurrentUser().then((user) => {
    if (user) redirectAfterAuth(user.role);
  });

  loginForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (error) error.hidden = true;

    const formData = new FormData(loginForm);
    const email = String(formData.get('email') || '').trim().toLowerCase();
    const password = String(formData.get('password') || '');

    setBusy(loginForm, true);
    const { error: signInError } = await supabaseBrowser.auth.signInWithPassword({
      email,
      password,
    });
    setBusy(loginForm, false);

    if (signInError) {
      showLoginError('Email hoặc mật khẩu chưa đúng.');
      return;
    }

    const user = await getCurrentUser();
    redirectAfterAuth(user?.role || 'user');
  });

  signupForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (signupMessage) signupMessage.hidden = true;

    const formData = new FormData(signupForm);
    const name = String(formData.get('name') || '').trim();
    const email = String(formData.get('email') || '').trim().toLowerCase();
    const password = String(formData.get('password') || '');

    if (!name || !email || password.length < 6) {
      showSignupMessage('Vui lòng nhập đủ thông tin và mật khẩu tối thiểu 6 ký tự.', 'error');
      return;
    }

    setBusy(signupForm, true);
    const { data, error: signUpError } = await supabaseBrowser.auth.signUp({
      email,
      password,
      options: { data: { name } },
    });
    setBusy(signupForm, false);

    if (signUpError) {
      const msg = /already registered|exists/i.test(signUpError.message)
        ? 'Email này đã có tài khoản. Bạn hãy đăng nhập.'
        : 'Không tạo được tài khoản: ' + signUpError.message;
      showSignupMessage(msg, 'error');
      return;
    }

    if (data.session) {
      // Xác nhận email đang tắt → đã đăng nhập luôn.
      const user = await getCurrentUser();
      redirectAfterAuth(user?.role || 'user');
    } else {
      // Xác nhận email đang bật → cần bấm link trong email.
      showSignupMessage('Đăng ký thành công. Vui lòng kiểm tra email để xác nhận rồi đăng nhập.', 'success');
      signupForm.reset();
    }
  });
</script>
