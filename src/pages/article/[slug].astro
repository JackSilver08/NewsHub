---
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';
import { marked } from 'marked';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getPublishedPosts, getRelatedPosts, isSupabasePost, postSlug } from '../../lib/posts';

// Bài Supabase soạn dạng Markdown → render đầy đủ (heading, list, in đậm,
// link, ảnh, blockquote, code…). `breaks: true` để xuống dòng đơn thành <br>.
marked.setOptions({ gfm: true, breaks: true });

export const getStaticPaths = (async () => {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: postSlug(post) },
    props: { post, all: posts },
  }));
}) satisfies GetStaticPaths;

const { post, all } = Astro.props;
const related = getRelatedPosts(post, all, 3);
const rendered = isSupabasePost(post) ? null : await render(post);

const supabaseHtml = isSupabasePost(post) ? (marked.parse(post.body) as string) : '';
const Content = rendered?.Content;
---

<ArticleLayout post={post} related={related}>
  {Content ? <Content /> : <div set:html={supabaseHtml} />}
</ArticleLayout>
