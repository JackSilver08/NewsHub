---
import { CATEGORIES } from '../lib/categories';
import SearchBox from './SearchBox.astro';
---

<header class="site-header">
  <div class="container header-inner">
    <div class="header-left">
      <a href="/" class="logo" aria-label="Công Nghệ Thường Nhật - Trang chủ">
        <img
          src="/assets/cong-nghe-thuong-nhat-logo.png"
          alt="Công Nghệ Thường Nhật"
          width="190"
          height="70"
        />
      </a>

      <div class="header-search">
        <SearchBox variant="header" />
      </div>
    </div>

    <div class="header-right">
      <div class="auth-actions" aria-label="Tài khoản">
        <a href="/login" class="auth-login" data-auth-login>Đăng nhập</a>
        <a href="/login?mode=signup" class="auth-signup" data-auth-signup>Đăng ký</a>
      </div>
      <button
        class="nav-toggle"
        aria-label="Mở menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- mobile sidebar drawer -->
  <div class="drawer-backdrop" data-backdrop></div>
  <aside id="mobile-nav" class="mobile-drawer" aria-label="Menu di động" aria-hidden="true" inert>
    <div class="drawer-top">
      <span class="drawer-title">Menu</span>
      <button class="drawer-close" type="button" data-drawer-close aria-label="Đóng menu">
        <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
    </div>

    <!-- Tài khoản (đầu sidebar) -->
    <div class="drawer-account">
      <div class="account-guest" data-auth-guest>
        <a href="/login" class="btn-outline">Đăng nhập</a>
        <a href="/login?mode=signup" class="btn-solid">Đăng ký</a>
      </div>
      <a href="/account" class="account-card" data-auth-user hidden>
        <span class="account-avatar" data-user-initial>N</span>
        <span class="account-info">
          <strong data-user-name>Tài khoản</strong>
          <small data-user-email></small>
        </span>
        <svg class="account-chevron" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>

    <!-- Chuyên mục (giữa) -->
    <nav class="drawer-nav" aria-label="Chuyên mục">
      <ul>
        <li><a href="/">Trang chủ</a></li>
        {CATEGORIES.map((cat) => (
          <li><a href={`/category/${cat.slug}`}>{cat.label}</a></li>
        ))}
        <li><a href="/search">Tìm kiếm</a></li>
      </ul>
    </nav>

    <!-- Đăng xuất (cuối sidebar) -->
    <div class="drawer-footer">
      <button type="button" class="btn-logout" data-drawer-logout hidden>
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path d="M15 12H3m0 0l4-4m-4 4l4 4M13 4h6a1 1 0 011 1v14a1 1 0 01-1 1h-6" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        Đăng xuất
      </button>
    </div>
  </aside>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    box-shadow: 0 1px 10px rgba(15, 23, 42, 0.04);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    min-height: 64px;
    max-width: var(--maxw);
    padding-inline: 40px;
  }
  .header-left {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .logo {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
  }
  .logo img {
    display: block;
    width: clamp(142px, 15vw, 190px);
    height: 48px;
    object-fit: contain;
    object-position: left center;
  }
  .header-search {
    flex: 0 1 360px;
    min-width: 220px;
  }
  .header-right {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .auth-actions {
    display: flex;
    gap: 8px;
  }
  .auth-actions a {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 0 14px;
    border-radius: 8px;
    font-family: var(--font-head);
    font-size: 0.8rem;
    font-weight: 800;
    line-height: 1;
  }
  .auth-login {
    border: 1px solid var(--border-strong);
    background: #fff;
    color: var(--text);
  }
  .auth-signup {
    background: #000;
    color: #fff;
  }
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 42px;
    height: 42px;
    padding: 0;
    background: var(--surface-container);
    border: 1px solid var(--border-strong);
    border-radius: 10px;
    cursor: pointer;
  }
  .nav-toggle span {
    display: block;
    height: 2px;
    width: 20px;
    margin-inline: auto;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .nav-toggle[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ===== Mobile sidebar drawer ===== */
  /* [hidden] bị display:flex/grid ghi đè → ép ẩn trong phạm vi drawer */
  .mobile-drawer [hidden] {
    display: none !important;
  }
  .drawer-backdrop {
    position: fixed;
    inset: 0;
    z-index: 55;
    background: rgba(15, 23, 42, 0.5);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }
  .drawer-backdrop.open {
    opacity: 1;
    pointer-events: auto;
  }
  .mobile-drawer {
    position: fixed;
    top: 0;
    right: 0;
    z-index: 60;
    display: flex;
    flex-direction: column;
    width: min(86vw, 340px);
    height: 100dvh;
    background: #fff;
    box-shadow: -12px 0 40px rgba(15, 23, 42, 0.18);
    transform: translateX(100%);
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    overflow-y: auto;
  }
  .mobile-drawer.open {
    transform: translateX(0);
  }
  .drawer-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
  }
  .drawer-title {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 0.95rem;
    color: var(--text);
  }
  .drawer-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border: 1px solid var(--border-strong);
    border-radius: 10px;
    background: var(--surface-container);
    color: var(--text);
    cursor: pointer;
  }
  /* Tài khoản (đầu sidebar) */
  .drawer-account {
    padding: 16px;
    border-bottom: 1px solid var(--border);
  }
  .account-guest {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .account-guest a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    border-radius: 10px;
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 0.85rem;
  }
  .btn-outline {
    border: 1px solid var(--border-strong);
    background: #fff;
    color: var(--text);
  }
  .btn-solid {
    background: #000;
    color: #fff;
  }
  .account-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--surface-low);
    color: var(--text);
  }
  .account-avatar {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: var(--nh-grad, var(--nh-purple));
    color: #fff;
    font-family: var(--font-head);
    font-weight: 800;
    text-transform: uppercase;
  }
  .account-info {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .account-info strong {
    font-size: 0.92rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .account-info small {
    color: var(--nh-muted);
    font-size: 0.78rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .account-chevron {
    flex: 0 0 auto;
    color: var(--nh-muted);
  }
  /* Chuyên mục (giữa) */
  .drawer-nav {
    flex: 1 1 auto;
    padding: 8px 12px;
  }
  .drawer-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 2px;
  }
  .drawer-nav a {
    display: block;
    padding: 13px 12px;
    color: var(--text);
    font-family: var(--font-head);
    font-weight: 600;
    border-radius: 10px;
  }
  .drawer-nav a:hover {
    background: var(--surface-low);
    color: var(--nh-purple);
  }
  /* Đăng xuất (cuối sidebar) */
  .drawer-footer {
    padding: 14px 16px calc(14px + env(safe-area-inset-bottom));
    border-top: 1px solid var(--border);
  }
  .btn-logout {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    min-height: 46px;
    border: 1px solid var(--border-strong);
    border-radius: 10px;
    background: #fff;
    color: #dc2626;
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 0.88rem;
    cursor: pointer;
  }
  .btn-logout:hover {
    background: #fef2f2;
    border-color: #fca5a5;
  }

  @media (max-width: 1080px) {
    .auth-actions {
      display: none;
    }
    .nav-toggle {
      display: flex;
    }
  }
  @media (max-width: 640px) {
    .header-inner {
      padding-inline: 16px;
    }
    .header-search {
      min-width: 0;
    }
  }
  @media (max-width: 460px) {
    .header-search {
      display: none;
    }
  }
</style>

<script>
  // ---- Mở/đóng sidebar ----
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const drawer = document.querySelector<HTMLElement>('#mobile-nav');
  const backdrop = document.querySelector<HTMLElement>('[data-backdrop]');
  const closeBtn = document.querySelector<HTMLButtonElement>('[data-drawer-close]');

  function setDrawer(open: boolean) {
    if (!drawer || !toggle) return;
    drawer.classList.toggle('open', open);
    drawer.setAttribute('aria-hidden', String(!open));
    if (open) drawer.removeAttribute('inert');
    else drawer.setAttribute('inert', '');
    backdrop?.classList.toggle('open', open);
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Đóng menu' : 'Mở menu');
    document.body.style.overflow = open ? 'hidden' : '';
  }

  toggle?.addEventListener('click', () =>
    setDrawer(!drawer?.classList.contains('open')),
  );
  closeBtn?.addEventListener('click', () => setDrawer(false));
  backdrop?.addEventListener('click', () => setDrawer(false));
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') setDrawer(false);
  });

  // ---- Trạng thái đăng nhập: nút header + tài khoản/đăng xuất trong sidebar ----
  const loginLink = document.querySelector<HTMLAnchorElement>('[data-auth-login]');
  const signupLink = document.querySelector<HTMLAnchorElement>('[data-auth-signup]');

  const guestBox = document.querySelector<HTMLElement>('[data-auth-guest]');
  const userCard = document.querySelector<HTMLAnchorElement>('[data-auth-user]');
  const userName = document.querySelector<HTMLElement>('[data-user-name]');
  const userEmail = document.querySelector<HTMLElement>('[data-user-email]');
  const userInitial = document.querySelector<HTMLElement>('[data-user-initial]');
  const logoutBtn = document.querySelector<HTMLButtonElement>('[data-drawer-logout]');

  import('../lib/supabaseBrowser').then(async ({ supabaseBrowser, getCurrentUser }) => {
    async function doLogout(event: Event) {
      event.preventDefault();
      await supabaseBrowser.auth.signOut();
      window.location.href = '/login';
    }
    logoutBtn?.addEventListener('click', doLogout);

    const user = await getCurrentUser();
    if (!user) return;

    const isStaff = user.role === 'admin' || user.role === 'moderator';
    const accountHref = isStaff ? '/admin/index.html' : '/account';

    // Nút ở header (desktop)
    if (loginLink && signupLink) {
      loginLink.href = accountHref;
      loginLink.textContent = isStaff ? 'Admin' : 'Tài khoản';
      signupLink.href = '#logout';
      signupLink.textContent = 'Đăng xuất';
      signupLink.addEventListener('click', doLogout);
    }

    // Thẻ tài khoản + nút đăng xuất trong sidebar
    if (userCard) {
      userCard.href = accountHref;
      userCard.hidden = false;
    }
    if (guestBox) guestBox.hidden = true;
    if (userName) userName.textContent = user.name || 'Tài khoản';
    if (userEmail) userEmail.textContent = user.email || '';
    if (userInitial) userInitial.textContent = (user.name || user.email || 'N').trim().charAt(0);
    if (logoutBtn) logoutBtn.hidden = false;
  });
</script>
