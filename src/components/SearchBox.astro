---
export interface Props {
  variant?: 'header' | 'page';
  placeholder?: string;
}
const { variant = 'page', placeholder = 'Tìm bài viết, chủ đề, tag…' } = Astro.props;
---

<form class={`search-box ${variant}`} action="/search" method="get" role="search">
  <label for={`q-${variant}`} class="visually-hidden">Tìm kiếm bài viết</label>
  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
    <circle cx="11" cy="11" r="7"></circle>
    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
  </svg>
  <input
    id={`q-${variant}`}
    type="search"
    name="q"
    placeholder={placeholder}
    autocomplete="off"
  />
</form>

<style>
  .search-box {
    display: flex;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
    padding: 8px 14px;
  }
  .search-box input {
    border: 0;
    background: transparent;
    outline: none;
    font: inherit;
    width: 100%;
    color: inherit;
  }
  .search-box input::placeholder {
    color: var(--nh-muted);
  }

  /* header variant: dark pill */
  .search-box.header {
    background: var(--surface-container);
    border: 1px solid transparent;
    color: var(--text);
    width: min(360px, 100%);
  }
  .search-box.header svg {
    color: var(--text-muted);
    flex: 0 0 auto;
  }

  /* page variant: light surface */
  .search-box.page {
    background: var(--surface);
    border: 1px solid var(--border-strong);
    color: var(--text);
    box-shadow: var(--shadow);
    padding: 12px 18px;
  }
  .search-box.page svg {
    color: var(--nh-purple);
    flex: 0 0 auto;
  }
</style>
